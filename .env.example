# Copy this file to .env and fill in real values. Never commit .env.

# ---------- Shared ----------
NODE_ENV=development
LOG_LEVEL=debug

# ---------- Database (Postgres) ----------
# For local Docker: postgresql://statify:statify@localhost:5432/statify
# For Neon: copy the pooled connection string. DIRECT_URL is the non-pooled string used by Prisma Migrate.
DATABASE_URL=postgresql://statify:statify@localhost:5432/statify?schema=public
DIRECT_URL=postgresql://statify:statify@localhost:5432/statify?schema=public

# ---------- API (apps/api) ----------
API_PORT=4000
API_BASE_URL=http://localhost:4000

# CORS: comma-separated allowlist
ALLOWED_ORIGINS=http://localhost:3000

# JWT
JWT_ACCESS_SECRET=replace-me-with-a-32-byte-random-string
JWT_REFRESH_SECRET=replace-me-with-a-different-32-byte-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Sentry (optional in dev)
SENTRY_DSN=

# iTunes Search API
ITUNES_API_BASE_URL=https://itunes.apple.com
ITUNES_RATE_LIMIT_RPS=20
ITUNES_REQUEST_TIMEOUT_MS=5000

# ---------- Web (apps/web) ----------
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_SENTRY_DSN=
